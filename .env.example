# ── Base de données PostgreSQL ──────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=phone_shop_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_NAME=phone_shop_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Authentification JWT ─────────────────────────────────────────────────────
# Clé secrète pour signer les tokens JWT (RS256 en production, HS256 en dev)
JWT_SECRET=change_me_to_a_strong_secret_in_production
JWT_EXPIRY=1h

# ── Serveur backend ───────────────────────────────────────────────────────────
PORT=3000
